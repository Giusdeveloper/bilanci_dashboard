# Supabase (client + script)
# Obbligatorie: senza queste l'app e gli script si fermano con un errore.
VITE_SUPABASE_URL=https://<your-project-ref>.supabase.co
VITE_SUPABASE_ANON_KEY=<SUPABASE_ANON_KEY>
# Solo per gli script lato server che richiedono privilegi elevati (NON esporre al client)
SUPABASE_SERVICE_ROLE_KEY=<SUPABASE_SERVICE_ROLE_KEY>

# Database (Neon PostgreSQL)
DATABASE_URL=postgresql://user:password@host/database

# Session
SESSION_SECRET=your-secret-key-here

# Server
PORT=5000
NODE_ENV=development

# GitHub (se usi l'integrazione GitHub)
GITHUB_TOKEN=your-github-token

# Replit (auto-configurate su Replit)
REPL_ID=
REPL_OWNER=
REPL_SLUG=
