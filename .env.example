# Supabase (client + script)
# Obbligatorie: senza queste l'app e gli script si fermano con un errore.
VITE_SUPABASE_URL=https://<your-project-ref>.supabase.co
# Publishable key (client-side). NON usare la legacy anon JWT (eyJ...): se disabilitata, login fallisce
# con "Legacy API keys are disabled". Dashboard → Settings → API Keys → Publishable key.
# Formato: sb_publishable_<random>_<checksum>
VITE_SUPABASE_ANON_KEY=sb_publishable_<your-publishable-key>
# Solo per gli script lato server che richiedono privilegi elevati (NON esporre al client).
# Preferire Secret key (sb_secret_...) se il progetto ha migrato; altrimenti service_role JWT legacy.
SUPABASE_SERVICE_ROLE_KEY=<SUPABASE_SECRET_OR_SERVICE_ROLE_KEY>

# Webhook n8n → Edge Function email-ingest (solo server/n8n, mai nel client).
INGEST_WEBHOOK_SECRET=<random-hex-secret>

# Database (Neon PostgreSQL)
DATABASE_URL=postgresql://user:password@host/database

# Session
SESSION_SECRET=your-secret-key-here

# Server
PORT=5000
NODE_ENV=development

# GitHub (se usi l'integrazione GitHub)
GITHUB_TOKEN=your-github-token

# Replit (auto-configurate su Replit)
REPL_ID=
REPL_OWNER=
REPL_SLUG=
